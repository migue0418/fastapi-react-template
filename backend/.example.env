# Nombre de la aplicación (aparece en /api/documentation)
APP_NAME=FastAPI Template

# Entorno: development | test | production
# Afecta CORS, logs, security headers (HSTS solo en production)
ENVIRONMENT=development

# Clave secreta para firmar los JWT. ¡Mínimo 32 caracteres en producción!
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key

# Duración del access token (minutos). Recomendado: 15 en producción
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Duración del refresh token (días)
REFRESH_TOKEN_EXPIRE_DAYS=7

# URL de conexión a PostgreSQL (driver asyncpg obligatorio)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/fastapi_template

# Credenciales del usuario administrador inicial
# Cámbialas inmediatamente tras el primer despliegue
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# URL de la BD administradora para crear/destruir la BD de tests
# Solo necesaria para ejecutar pytest localmente
TEST_DATABASE_ADMIN_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres

# URL del frontend en producción (usada para configurar CORS)
# Solo necesaria cuando ENVIRONMENT=production
FRONTEND_URL=https://tu-dominio.com
